# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── DASHBOARD AUTH ────────────────────────────────────────────────────────────
# Required — dashboard will not start if these are missing
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# ── BOTS ──────────────────────────────────────────────────────────────────────
# Add one block per bot. BOT_1, BOT_2, etc.
# TARGET_WALLET: the Polymarket proxy wallet address you are copying
# TARGET_CAPITAL: approximate USD capital the target deploys (used for scaling)
BOT_1_NAME=
BOT_1_TARGET_WALLET=
BOT_1_TARGET_CAPITAL=

# BOT_2_NAME=
# BOT_2_TARGET_WALLET=
# BOT_2_TARGET_CAPITAL=

# ── TRADING ───────────────────────────────────────────────────────────────────
TRADING_MODE=paper          # paper | live
INITIAL_PORTFOLIO_USD=100

# ── DATABASE ──────────────────────────────────────────────────────────────────
DB_PATH=data/polyfarm.db    # local dev path; /app/data/polyfarm.db in Docker
LOG_LEVEL=INFO

# ── TELEGRAM (Phase 2) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LIVE TRADING (Phase 3) ────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
WALLET_PRIVATE_KEY=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
