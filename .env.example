# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # your personal chat ID (get from @userinfobot)

# ── TRADING ───────────────────────────────────────────────────────────────────
TRADING_MODE=paper          # paper | live
INITIAL_PORTFOLIO_USD=100

# ── DATABASE ──────────────────────────────────────────────────────────────────
DB_PATH=data/polyfarm.db    # local dev path; /app/data/polyfarm.db in Docker
LOG_LEVEL=INFO

# ── FILLED WHEN GOING LIVE (Phase 3) ─────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
WALLET_PRIVATE_KEY=         # bot execution wallet private key — NEVER your dev wallet
CLOB_API_KEY=               # from Polymarket API key registration
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
