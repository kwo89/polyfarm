# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── DASHBOARD AUTH ────────────────────────────────────────────────────────────
# Required — dashboard will not start if these are missing
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# ── BOTS ──────────────────────────────────────────────────────────────────────
# One block per bot. Name must match config.yml exactly (case-insensitive, spaces→underscores).
# Convention: BOT_{UPPERNAME}_TARGET_WALLET / BOT_{UPPERNAME}_TARGET_CAPITAL
# e.g. name "Bot1" → BOT_BOT1_TARGET_WALLET
# TARGET_WALLET: the Polymarket proxy wallet address you are copying
# TARGET_CAPITAL: initial estimate of target's daily USD volume (auto-calibrated weekly)

BOT_BOT1_TARGET_WALLET=
BOT_BOT1_TARGET_CAPITAL=2000

BOT_BOT2_TARGET_WALLET=
BOT_BOT2_TARGET_CAPITAL=2000

# ── TRADING ───────────────────────────────────────────────────────────────────
TRADING_MODE=paper          # paper | live
INITIAL_PORTFOLIO_USD=100

# ── DATABASE ──────────────────────────────────────────────────────────────────
DB_PATH=data/polyfarm.db    # local dev path; /app/data/polyfarm.db in Docker
LOG_LEVEL=INFO

# ── AUTO-DEPLOY WEBHOOK ───────────────────────────────────────────────────────
# Generated automatically by scripts/webhook_setup.sh — do not set manually
WEBHOOK_SECRET=
WEBHOOK_PORT=9000

# ── TELEGRAM (Phase 2) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LIVE TRADING (Phase 3) ────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
WALLET_PRIVATE_KEY=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
